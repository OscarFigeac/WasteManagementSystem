<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Go <span style="color: #00a19a;">Premium</span></h1>
        <p class="lead text-muted">Support a greener planet.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header py-3 bg-white">
                    <h4 class="my-0 fw-normal text-center">Basic</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">€0 <small class="text-muted">/ mo</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><i class="bi bi-check-circle text-success"></i> Track up to 20 items</li>
                        <li><i class="bi bi-check-circle text-success"></i> Basic Waste History</li>
                        <li class="text-muted"><i class="bi bi-x-circle"></i> Advanced Analytics</li>
                    </ul>
                    <button type="button" class="btn btn-lg btn-block btn-outline-secondary w-100" disabled>Current Plan</button>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4 shadow-lg border-primary">
                <div class="card-header py-3 text-white bg-dark">
                    <h4 class="my-0 fw-normal text-center">Premium</h4>
                </div>
                <div class="card-body">
                    <h1 class="card-title pricing-card-title text-center">€4.99 <small class="text-muted">/ mo</small></h1>
                    <ul class="list-unstyled mt-3 mb-4">
                        <li><i class="bi bi-check-circle text-success"></i> Unlimited Inventory</li>
                        <li><i class="bi bi-check-circle text-success"></i> <strong>Full Analytics Suite</strong></li>
                        <li><i class="bi bi-check-circle text-success"></i> Export Data (JSON API)</li>
                    </ul>
                    <form asp-action="ProcessPayment" method="post">
                        <button type="submit" class="btn btn-lg btn-block btn-primary w-100" style="background-color: #00a19a; border: none;">Upgrade Now</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>