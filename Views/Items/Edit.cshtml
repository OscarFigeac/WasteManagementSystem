@model WasteManagementSystem.Models.Item

@{
    ViewData["Title"] = "Edit Item";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-header bg-white border-0 pt-4 ps-4">
                    <h2 class="fw-bold" style="color: #2c3e50;">Edit <span style="color: #00a19a;">@Model.ItemName</span></h2>
                    <p class="text-muted">Modify the details of this item below.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label asp-for="ItemName" class="form-label small fw-bold text-uppercase text-muted">Item Name</label>
                                <input asp-for="ItemName" class="form-control border-0 bg-light" style="height: 45px;" />
                                <span asp-validation-for="ItemName" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Value" class="form-label small fw-bold text-uppercase text-muted">Value (€)</label>
                                <input asp-for="Value" class="form-control border-0 bg-light" style="height: 45px;" />
                                <span asp-validation-for="Value" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Category" class="form-label small fw-bold text-uppercase text-muted">Category</label>
                                <select asp-for="Category" class="form-select border-0 bg-light" style="height: 45px;"
                                        asp-items="Html.GetEnumSelectList<WasteManagementSystem.Models.ItemCategory>()"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HouseDetailsId" class="form-label small fw-bold text-uppercase text-muted">Household</label>
                                <select asp-for="HouseDetailsId" class="form-select border-0 bg-light" style="height: 45px;" asp-items="ViewBag.HouseDetailsId"></select>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label asp-for="ExpiryDate" class="form-label small fw-bold text-uppercase text-muted">Expiry Date</label>
                                <input asp-for="ExpiryDate" class="form-control border-0 bg-light" type="date" style="height: 45px;" />
                                <span asp-validation-for="ExpiryDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">Cancel</a>
                            <button type="submit" class="btn btn-lg px-5 fw-bold" style="background-color: #2c3e50; color: white; border-radius: 8px;">
                                Update Item
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}