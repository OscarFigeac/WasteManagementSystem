@model WasteManagementSystem.Models.DTOs.ItemDTO

@{
    ViewData["Title"] = "Delete Item";
}

<div class="container mt-4">
    <h1 class="text-danger">Delete Confirmation</h1>
    <div class="alert alert-warning">
        <h4 class="alert-heading">Warning!</h4>
        <p>Are you sure you want to permanently delete <strong>@Model.Name</strong> from the inventory?</p>
    </div>

    <div>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Item Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category</dd>

            <dt class="col-sm-3">Assigned House</dt>
            <dd class="col-sm-9">@Model.HouseAddress</dd>

            <dt class="col-sm-3">Environmental Impact</dt>
            <dd class="col-sm-9">@Model.WasteImpact</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="mt-4">
                <button type="submit" class="btn btn-danger btn-lg">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>