@model IEnumerable<WasteManagementSystem.Models.DTOs.ItemDTO>

@{
    ViewData["Title"] = "Waste Inventory";
}

<h1>Waste Inventory</h1>

<p>
    <a asp-action="Create">Add New Item</a>
</p>
<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                   class="form-control" placeholder="Search by name" />
        </div>
        <div class="col-md-3">
            <select name="itemCategory" class="form-control">
                <option value="">All Categories</option>
                @foreach (var cat in Enum.GetValues(typeof(WasteManagementSystem.Models.ItemCategory)))
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th>@Html.DisplayNameFor(model => model.ExpiryStatus)</th>
            <th>@Html.DisplayNameFor(model => model.DaysRemaining)</th>
            <th>@Html.DisplayNameFor(model => model.FinancialValue)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Category)</td>
            <td>
                @* Custom logic: Show 'Expired' in red *@
                @if (item.ExpiryStatus == "Expired")
                {
                    <span class="text-danger fw-bold">@item.ExpiryStatus</span>
                }
                else
                {
                    <span class="text-success">@item.ExpiryStatus</span>
                }
            </td>
            <td>@item.DaysRemaining days</td>
            <td>@item.FinancialValue.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
        </tr>
}
    </tbody>
</table>