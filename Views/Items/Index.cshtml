@model IEnumerable<WasteManagementSystem.Models.DTOs.ItemDTO>

@{
    ViewData["Title"] = "My Pantry";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="fw-bold" style="color: #2c3e50;">My <span style="color: #00a19a;">Pantry</span></h1>
            <p class="text-muted mb-0">Manage your household inventory and reduce food waste.</p>
        </div>
        <a asp-action="Create" class="btn btn-lg fw-bold" style="background-color: #00a19a; color: white; border-radius: 8px;">
            + Add New Item
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-uppercase text-muted">Search Items</label>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control border-0 bg-light" placeholder="e.g. 'Beef' or 'Milk'..." style="height: 45px;" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-uppercase text-muted">Category</label>
                    <select name="itemCategory" class="form-select border-0 bg-light" style="height: 45px;">
                        <option value="">All Categories</option>
                        @foreach (var cat in Enum.GetValues(typeof(WasteManagementSystem.Models.ItemCategory)))
                        {
                            <option value="@cat" selected="@(ViewData["CurrentCategory"]?.ToString() == cat.ToString())">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark w-100 fw-bold" style="height: 45px; border-radius: 8px;">Apply Filters</button>
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted ms-2">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Item Name</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Category</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Status</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Days Left</th>
                        <th class="py-3 text-uppercase small fw-bold text-muted">Household</th>
                        <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="small text-muted">ID: #@item.Id</div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-light text-dark border px-3">@item.Category</span>
                            </td>
                            <td>
                                @if (item.ExpiryStatus == "Expired")
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Safe</span>
                                }
                            </td>
                            <td class="fw-bold @(int.Parse(item.DaysRemaining) < 3 ? "text-danger" : "text-dark")">
                                @item.DaysRemaining days
                            </td>
                            <td>
                                <i class="bi bi-house-door me-1"></i> @item.HouseAddress
                            </td>
                            <td class="pe-4 text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary border-0">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="LogWaste" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning border-0 fw-bold">
                                        Log Waste
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger border-0">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <p class="text-muted italic">No items found matching your search.</p>
            </div>
        }
    </div>
</div>