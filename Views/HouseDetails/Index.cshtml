@model IEnumerable<WasteManagementSystem.Models.HouseDetails>
@{
    ViewData["Title"] = "House List";
}

<div class="container mt-4">
    <h2>Registered Households</h2>
    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.Address)</th>
                <th>@Html.DisplayNameFor(model => model.Eircode)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Address)</td>
                    <td>@Html.DisplayFor(modelItem => item.Eircode)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Eircode">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Eircode">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Eircode">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>