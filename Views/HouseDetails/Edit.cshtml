@model WasteManagementSystem.Models.HouseDetails
@{
    ViewData["Title"] = "Edit Household";
}

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Eircode" />

    <div class="form-group mb-3">
        <label asp-for="Address" class="control-label"></label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Eircode" class="control-label"></label>
        <input asp-for="Eircode" class="form-control" disabled />
    </div>

    <input type="submit" value="Save" class="btn btn-primary" />
    <a asp-action="Index">Back to List</a>
</form>