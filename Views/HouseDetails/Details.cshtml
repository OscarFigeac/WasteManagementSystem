@model WasteManagementSystem.Models.HouseDetails

<div class="container mt-4">
    <div class="card border-0 shadow-sm p-4">
        <h2 class="fw-bold" style="color: #2c3e50;">Household <span style="color: #00a19a;">Details</span></h2>
        <hr />
        <dl class="row">
            <dt class="col-sm-3 text-muted text-uppercase small fw-bold">Eircode</dt>
            <dd class="col-sm-9 fw-bold">@Model.Eircode</dd>

            <dt class="col-sm-3 text-muted text-uppercase small fw-bold">Registered Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>
        </dl>
        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Eircode" class="btn btn-primary">Edit Info</a>
            <a asp-controller="Items" asp-action="Index" class="btn btn-outline-secondary">Go to Pantry</a>
        </div>
    </div>
</div>