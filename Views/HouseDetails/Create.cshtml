@model WasteManagementSystem.Models.HouseDetails

<div class="container mt-5">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body p-4">
            <h3 class="fw-bold text-center mb-4">Register <span style="color: #00a19a;">Household</span></h3>
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Eircode" class="form-label small fw-bold"></label>
                    <input asp-for="Eircode" class="form-control" placeholder="e.g. D01A2B3" />
                    <span asp-validation-for="Eircode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label small fw-bold"></label>
                    <input asp-for="Address" class="form-control" placeholder="Full Address" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label small fw-bold"></label>
                    <input asp-for="Password" type="password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-lg w-100 fw-bold text-white" style="background-color: #00a19a;">Sign Up</button>
            </form>
        </div>
    </div>
</div>